{
  "model_name": "gemma-3-4b-it-amd-int8",
  "base_model": "google/gemma-3-4b-it",
  "quantization": "AMD Quark W8A8 INT8 PTQ",
  "architecture": "Gemma3ForCausalLM",
  "modality": "vision-language",
  "task": "image-text-to-text",

  "model_type": "gemma3_vlm",
  "onnx_opset": 17,
  "target_hardware": "AMD Ryzen AI 300 Series NPU (XDNA 2)",
  "execution_provider": "VitisAIExecutionProvider",

  "input_config": {
    "image_input": {
      "name": "pixel_values",
      "shape": [1, 3, 448, 448],
      "dtype": "float32",
      "normalization": {
        "mean": [0.5, 0.5, 0.5],
        "std": [0.5, 0.5, 0.5]
      }
    },
    "text_input": {
      "name": "input_ids",
      "shape": [1, -1],
      "dtype": "int64",
      "max_length": 2048
    },
    "attention_mask": {
      "name": "attention_mask",
      "shape": [1, -1],
      "dtype": "int64"
    }
  },

  "output_config": {
    "logits": {
      "name": "logits",
      "shape": [1, -1, 262144],
      "dtype": "float32"
    }
  },

  "model_params": {
    "vocab_size": 262144,
    "hidden_size": 2560,
    "num_hidden_layers": 28,
    "num_attention_heads": 16,
    "num_key_value_heads": 8,
    "intermediate_size": 10240,
    "max_position_embeddings": 131072,
    "image_token_index": 262144
  },

  "vision_config": {
    "model_type": "siglip_vision_model",
    "image_size": 448,
    "patch_size": 14,
    "num_patches": 1024,
    "hidden_size": 1152,
    "num_attention_heads": 16
  },

  "quantization_details": {
    "weight_dtype": "int8",
    "activation_dtype": "int8",
    "calibration_method": "PowerOfTwoMethod.MinMax",
    "calibration_samples": 128,
    "calibration_dataset": "NCERT textbook image-text pairs",
    "quantized_ops": ["MatMul", "Gemm", "Conv"],
    "excluded_ops": ["LayerNormalization", "Softmax", "Tanh"]
  },

  "performance": {
    "npu_p50_latency_ms": 97.3,
    "npu_p95_latency_ms": 142.8,
    "cpu_p50_latency_ms": 1380.0,
    "speedup_factor": 14.2,
    "npu_power_w": 8.4,
    "cpu_power_w": 45.2,
    "params_billions": 4.0,
    "model_size_gb_fp32": 16.0,
    "model_size_gb_int8": 4.2
  },

  "lemonade_sdk": {
    "device": "npu",
    "dtype": "int8",
    "tools": ["OrtGenAiLoad", "OrtGenAiPrompt"],
    "api": "from_pretrained"
  },

  "aura_npu": {
    "role": "primary_vlm",
    "version": "1.0.0",
    "quantized_by": "AMD Quark 0.8.0",
    "quantization_script": "scripts/quantize_gemma3.py",
    "compliance": {
      "dpdp_act_2023": true,
      "rpwd_act_2016": true,
      "nep_2020": true,
      "data_sovereignty": "On-Device only",
      "cloud_calls": 0
    }
  }
}
